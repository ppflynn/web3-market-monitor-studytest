# Copy this file to .env and fill in your real provider settings.
#
# DeepSeek example:
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=

# Generic OpenAI-compatible key. If both are set, AI_API_KEY is preferred.
# AI_API_KEY=

AI_TIMEOUT_SECONDS=30
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=800
AI_STREAM=false

# DeepSeek reasoning options. Disable them if your selected model does not support them.
AI_THINKING_ENABLED=true
AI_REASONING_EFFORT=high

# Embeddings are used for Chroma-backed project RAG.
# If EMBEDDING_API_KEY is empty, the service falls back to AI_API_KEY / DEEPSEEK_API_KEY.
# Use a provider and model that expose an OpenAI-compatible /embeddings endpoint.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BATCH_SIZE=48

# FastAPI reads market data from the Spring Boot API before calling the LLM.
# Use http://backend:8080/api inside Docker Compose.
SPRING_API_BASE_URL=http://localhost:8080/api
SPRING_API_TIMEOUT_SECONDS=10

# Local project RAG. Docker Compose overrides RAG_ROOT_PATH to /workspace
# and CHROMA_PERSIST_DIR to /data/chroma.
RAG_ENABLED=true
RAG_ROOT_PATH=
RAG_INCLUDE_PATHS=README.md,fastapi-ai,src/main/java,src/main/resources,frontend/coin-market-web/src,scripts
RAG_EXCLUDE_DIRS=.git,.idea,.vscode,.mvn,.venv,venv,target,node_modules,dist,__pycache__
RAG_MAX_FILES=120
RAG_MAX_FILE_BYTES=200000
RAG_CHUNK_CHARS=1400
RAG_SNIPPET_CHARS=1200
RAG_MAX_SOURCES=5
RAG_MIN_SCORE=1.2
RAG_REINDEX_ON_START=false
CHROMA_PERSIST_DIR=./chroma-data
CHROMA_COLLECTION_NAME=project_rag

# Structured market tool layer backed by the Spring Boot API.
MARKET_TOOLS_ENABLED=true
MARKET_TOOL_DEFAULT_HISTORY_DAYS=7
MARKET_TOOL_MAX_HISTORY_DAYS=30
MARKET_TOOL_MAX_CONTEXT_CHARS=8000
