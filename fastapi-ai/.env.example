# Copy this file to .env and fill in your real provider settings.
#
# DeepSeek example:
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=

# Generic OpenAI-compatible key. If both are set, AI_API_KEY is preferred.
# AI_API_KEY=

AI_TIMEOUT_SECONDS=30
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=800
AI_STREAM=false

# DeepSeek reasoning options. Disable them if your selected model does not support them.
AI_THINKING_ENABLED=true
AI_REASONING_EFFORT=high

# FastAPI reads market data from the Spring Boot API before calling the LLM.
# Use http://backend:8080/api inside Docker Compose.
SPRING_API_BASE_URL=http://localhost:8080/api
SPRING_API_TIMEOUT_SECONDS=10
